{
  "name": "web",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "deno:clean": "rimraf .output .tanstack .turbo dist",
    "build:deno:linux:x64": "deno compile --allow-net --allow-read --allow-env --include .output --target x86_64-unknown-linux-gnu --output dist/aidoris-web-linux-x64 .output/server/index.mjs",
    "build:deno:linux:arm64": "deno compile --allow-net --allow-read --allow-env --include .output --target aarch64-unknown-linux-gnu --output dist/aidoris-web-linux-arm64 .output/server/index.mjs",
    "build:deno:darwin:x64": "deno compile --allow-net --allow-read --allow-env --include .output --target x86_64-apple-darwin --output dist/aidoris-web-darwin-x64 .output/server/index.mjs",
    "build:deno:darwin:arm64": "deno compile --allow-net --allow-read --allow-env --include .output --target aarch64-apple-darwin --output dist/aidoris-web-darwin-arm64 .output/server/index.mjs",
    "build:deno:windows:x64": "deno compile --allow-net --allow-read --allow-env --include .output --target x86_64-pc-windows-msvc --output dist/aidoris-web-windows-x64.exe .output/server/index.mjs",
    "build:deno:all": "npm-run-all -s build deno:prepare build:deno:linux:x64 build:deno:linux:arm64 build:deno:darwin:x64 build:deno:darwin:arm64 build:deno:windows:x64",
    "deno:prepare": "npm-run-all -s deno:clean deno:prepare:run",
    "deno:prepare:run": "node -e \"require('fs').mkdirSync('.output',{recursive:true})\" && vite build"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.1.6",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-start": "^1.132.0",
    "@tanstack/router-plugin": "^1.132.0",
    "@workspace/ui": "workspace:*",
    "nitro": "latest",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.1.18",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "devDependencies": {
    "@tanstack/eslint-config": "^0.3.0",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "deno": "^2.7.4",
    "eslint": "^9.39.2",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vite": "^7.2.4"
  }
}
